# ── База данных ──────────────────────────────────────────────────────────────
# PostgreSQL (рекомендуется, бесплатно на neon.tech или supabase.com)
DATABASE_URL="postgresql://user:password@host:5432/pravoimeyu?sslmode=require"

# Для локальной разработки без PostgreSQL: поменяй provider на "sqlite"
# в prisma/schema.prisma и используй:
# DATABASE_URL="file:./dev.db"

# ── Сессия ───────────────────────────────────────────────────────────────────
# Минимум 32 символа, ОБЯЗАТЕЛЬНО поменять в production!
SESSION_PASSWORD="change-me-to-a-random-32-char-secret!!"

# ── URL приложения ────────────────────────────────────────────────────────────
APP_URL="http://localhost:3000"

# ── SMTP (опционально) ───────────────────────────────────────────────────────
# Если не указан — письма сохраняются в /emails/*.txt (режим разработки)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your@gmail.com"
SMTP_PASS="app-password-from-google-account"
SMTP_FROM="Право имею <noreply@pravoimeyu.ru>"
