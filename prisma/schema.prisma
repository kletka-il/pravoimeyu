generator client {
  provider = "prisma-client-js"
}

// Для локальной разработки можно оставить sqlite + file:./dev.db
// Для production смените на postgresql и обновите DATABASE_URL
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  phone         String    @default("")
  address       String    @default("")
  role          String    @default("CLIENT")
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  chatUsed         Int       @default(0)

  verifyTokens     VerifyToken[]
  resetTokens      PasswordResetToken[]
  searches         SearchLog[]
  specialist       SpecialistProfile?
  ownedFirm        LawFirm?
  bookingsClient   Booking[]             @relation("BookingClient")
  authoredArticles Article[]             @relation("ArticleAuthor")
  messagesSent     Message[]             @relation("MessageSender")
  uploadedDocs     Document[]            @relation("DocumentUploader")
}

model VerifyToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model SpecialistProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  status          String   @default("PENDING")
  yearsExperience Int      @default(0)
  bio             String   @default("")
  city            String   @default("")
  phone           String   @default("")
  pricePerHour    Int      @default(0)
  rating          Float    @default(0)
  reviewsCount    Int      @default(0)
  specializations Json     @default("[]")
  credentials     Json     @default("[]")
  avatarUrl       String   @default("")
  firmId          String?
  firm            LawFirm? @relation(fields: [firmId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bookings Booking[] @relation("BookingSpecialist")

  @@index([status])
  @@index([firmId])
}

model LawFirm {
  id          String   @id @default(cuid())
  name        String
  inn         String   @default("")
  address     String   @default("")
  phone       String   @default("")
  website     String   @default("")
  description String   @default("")
  status      String   @default("PENDING")
  ownerId     String   @unique
  owner       User     @relation(fields: [ownerId], references: [id])
  members     SpecialistProfile[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
}

model Category {
  id                String    @id @default(cuid())
  slug              String    @unique
  title             String
  description       String    @default("")
  icon              String    @default("⚖️")
  specializationKey String    @default("general")
  order             Int       @default(0)
  articles          Article[]
}

model Article {
  id              String   @id @default(cuid())
  slug            String   @unique
  title           String
  shortAnswer     String
  body            String
  keywords        Json     @default("[]")
  lawRefs         Json     @default("[]")
  urgency         Int      @default(2)
  categoryId      String
  category        Category @relation(fields: [categoryId], references: [id])
  authorId        String?
  author          User?    @relation("ArticleAuthor", fields: [authorId], references: [id])
  isPublished     Boolean  @default(true)
  status          String   @default("APPROVED")
  rejectionReason String   @default("")
  views           Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([categoryId])
  @@index([slug])
  @@index([status])
}

model SearchLog {
  id           String   @id @default(cuid())
  query        String
  userId       String?
  user         User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  resultsCount Int      @default(0)
  topArticleId String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

model Booking {
  id           String            @id @default(cuid())
  clientId     String
  client       User              @relation("BookingClient", fields: [clientId], references: [id], onDelete: Cascade)
  specialistId String
  specialist   SpecialistProfile @relation("BookingSpecialist", fields: [specialistId], references: [id], onDelete: Cascade)
  question     String
  contactPhone String            @default("")
  status       String            @default("NEW")
  fromChat     Boolean           @default(false)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  messages  Message[]
  documents Document[]

  @@index([clientId])
  @@index([specialistId])
  @@index([status])
}

model Message {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation("MessageSender", fields: [senderId], references: [id])
  text      String
  createdAt DateTime @default(now())

  @@index([bookingId])
  @@index([senderId])
}

model Document {
  id         String   @id @default(cuid())
  bookingId  String
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  uploaderId String
  uploader   User     @relation("DocumentUploader", fields: [uploaderId], references: [id])
  name       String
  path       String
  size       Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([bookingId])
}

model Win {
  id          String   @id @default(cuid())
  title       String
  summary     String
  body        String
  amount      String   @default("")
  category    String   @default("")
  publishedAt DateTime @default(now())
  isPublished Boolean  @default(true)
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String   @default("")
  message   String
  createdAt DateTime @default(now())
  isRead    Boolean  @default(false)
}

model TelegramSession {
  chatId    BigInt   @id
  step      String   @default("WAITING_NAME")
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt
}
